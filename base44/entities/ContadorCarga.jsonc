      "description": "Identificador da sequ\u00eancia (sempre 'global' nesta app)"
    },
    "ultimo_numero": {
      "type": "number",
      "default": 0,
      "description": "\u00daltimo n\u00famero de carga emitido"
    }
  },
  "required": [
    "chave"
  ]
}