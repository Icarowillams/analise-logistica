{
  "name": "ContadorCarga",
  "type": "object",
  "description": "Sequ\u00eancia persistente de numera\u00e7\u00e3o de cargas. Nunca decrementa \u2014 independe de cancelamento/exclus\u00e3o de cargas.",
  "properties": {
    "chave": {
      "type": "string",
