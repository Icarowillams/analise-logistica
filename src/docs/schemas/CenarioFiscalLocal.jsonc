{"name":"CenarioFiscalLocal","type":"object","description":"Cenário fiscal local cadastrado no Base (ex: Venda, Bonificação, Troca). Quando o cliente é Nota 55, este cenário pode ser vinculado a um CenarioFiscal do Omie via cenario_omie_id. Para Nota D1, nunca usa Omie — operação totalmente interna.","properties":{"nome":{"type":"string","description":"Nome do cenário local (ex: Venda, Bonificação, Troca)"},"tipo_operacao":{"type":"string","enum":["venda","bonificacao","troca","devolucao","remessa","transferencia","outros"],"default":"venda"},"descricao":{"type":"string"},"cenario_omie_id":{"type":"string","description":"ID do registro CenarioFiscal (Omie) vinculado — usado apenas quando cliente é Nota 55"},"cenario_omie_nome":{"type":"string","description":"Nome do cenário Omie vinculado (cache para exibição)"},"cenario_omie_codigo":{"type":"string","description":"Código (nCodigo) do cenário Omie vinculado"},"padrao":{"type":"boolean","default":false,"description":"Se é o cenário padrão para este tipo de operação"},"status":{"type":"string","enum":["ativo","inativo"],"default":"ativo"},"observacoes":{"type":"string"}},"required":["nome","tipo_operacao"]}