{"name":"ConfiguracaoSistema","type":"object","description":"Configurações globais do sistema para controlar otimizações operacionais sem deploy","properties":{"chave":{"type":"string","default":"global","description":"Identificador único da configuração global"},"modo_economico":{"type":"boolean","default":false,"description":"Quando ativo, aumenta caches e reduz sincronizações automáticas para economizar créditos"}},"required":["chave"]}