{"name":"ParametroNaturezaOperacao","type":"object","description":"Cadastro de naturezas de operação / CFOPs — usadas em emissão de pedidos, cortes e devoluções. Diferente de CenarioFiscal (que vem do Omie), esta é uma configuração local flexível.","properties":{"cfop":{"type":"string","description":"Código CFOP (ex: 5102, 5202, 5929)"},"descricao":{"type":"string"},"tipo_operacao":{"type":"string","enum":["venda","devolucao","remessa","bonificacao","troca","transferencia","outros"],"default":"venda"},"dentro_estado":{"type":"boolean","default":true,"description":"CFOP usado para operações dentro do estado (5xxx)"},"cenario_fiscal_id":{"type":"string","description":"ID do CenarioFiscal Omie associado"},"codigo_cenario_impostos":{"type":"string","description":"nCodigo do cenário Omie"},"padrao":{"type":"boolean","default":false,"description":"Se é o CFOP padrão para este tipo de operação"},"ativo":{"type":"boolean","default":true},"observacoes":{"type":"string"}},"required":["cfop","tipo_operacao"]}