{"name":"LogIntegracaoOmie","type":"object","description":"Auditoria de todas as chamadas feitas à API Omie","properties":{"endpoint":{"type":"string","description":"Endpoint Omie (ex: geral/clientes)"},"call":{"type":"string","description":"Método da call (ex: UpsertCliente, IncluirPedido)"},"operacao":{"type":"string","description":"Operação de negócio (ex: enviar_cliente, faturar_pedido)"},"entidade_tipo":{"type":"string","description":"Tipo da entidade Base44 relacionada (Cliente, Produto, PedidoVenda...)"},"entidade_id":{"type":"string","description":"ID da entidade Base44 relacionada"},"status":{"type":"string","enum":["sucesso","erro","warning","pendente","processado","ignorado"],"default":"sucesso"},"codigo_erro":{"type":"string","description":"Código de erro retornado pelo Omie (faultcode)"},"mensagem_erro":{"type":"string","description":"Mensagem de erro (faultstring ou mensagem interna)"},"payload_enviado":{"type":"string","description":"JSON enviado ao Omie (truncado se muito grande)"},"payload_resposta":{"type":"string","description":"JSON retornado pelo Omie (truncado se muito grande)"},"duracao_ms":{"type":"number","description":"Tempo total da chamada em milissegundos"},"tentativas":{"type":"number","default":1,"description":"Número de tentativas realizadas"},"usuario_email":{"type":"string","description":"Email do usuário que disparou a ação (quando aplicável)"},"webhook_topic":{"type":"string","description":"Topic do webhook Omie (ex: VendaProduto.Faturada)"},"webhook_message_id":{"type":"string","description":"messageId do webhook Omie — usado para idempotência"},"webhook_processado_em":{"type":"string","format":"date-time","description":"Quando o webhook foi processado pelo handler assíncrono"}},"required":["endpoint","call","status"]}