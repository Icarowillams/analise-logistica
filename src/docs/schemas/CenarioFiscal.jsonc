{"name":"CenarioFiscal","type":"object","description":"Cenário fiscal para emissão de notas — naturezas de operação e etapas de faturamento do Omie","properties":{"tipo_registro":{"type":"string","enum":["cenario","etapa"],"default":"cenario","description":"cenario = Natureza de Operação (ListarCenarios); etapa = Etapa de Faturamento (ListarEtapasFaturamento)"},"codigo":{"type":"string","description":"Código do cenário fiscal ou etapa"},"nome":{"type":"string","description":"Nome do cenário fiscal"},"descricao":{"type":"string"},"cfop":{"type":"string","description":"CFOP padrão do cenário"},"natureza_operacao":{"type":"string","description":"Natureza da operação (Ex: Venda de mercadoria)"},"tipo_nota":{"type":"string","enum":["55","D1","65"],"default":"55","description":"Tipo/modelo de nota fiscal (55 = NF-e, D1 = interna sem NF, 65 = NFC-e)"},"cst_icms":{"type":"string","description":"CST/CSOSN de ICMS"},"aliquota_icms":{"type":"number","description":"Alíquota de ICMS (%)"},"cst_pis":{"type":"string"},"aliquota_pis":{"type":"number"},"cst_cofins":{"type":"string"},"aliquota_cofins":{"type":"number"},"omie_id":{"type":"string","description":"ID do cenário correspondente no Omie (nCodigo) ou cCodigo da etapa"},"padrao":{"type":"boolean","default":false,"description":"Se é cenário/etapa marcado como padrão no Omie"},"status":{"type":"string","enum":["ativo","inativo"],"default":"ativo"},"observacoes":{"type":"string"}},"required":["nome"]}