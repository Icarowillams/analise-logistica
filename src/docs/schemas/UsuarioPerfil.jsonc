{"name":"UsuarioPerfil","type":"object","description":"Vínculo entre usuário do sistema e seu perfil de acesso","properties":{"user_id":{"type":"string","description":"ID do usuário (entidade User built-in)"},"user_email":{"type":"string"},"user_nome":{"type":"string"},"perfil_id":{"type":"string","description":"ID do Perfil"},"perfil_codigo":{"type":"string","enum":["administrador","auxiliar_expedicao","motorista","supervisor","vendedor","gerente"]},"vendedor_id":{"type":"string","description":"Funcionário/Vendedor correspondente no sistema"},"motorista_id":{"type":"string","description":"Motorista correspondente (quando perfil = motorista)"},"permissoes_extras":{"type":"array","items":{"type":"string"},"default":[],"description":"Permissões adicionais além do perfil padrão"},"permissoes_bloqueadas":{"type":"array","items":{"type":"string"},"default":[],"description":"Permissões removidas em relação ao perfil padrão"},"ativo":{"type":"boolean","default":true}},"required":["user_id","perfil_id"]}