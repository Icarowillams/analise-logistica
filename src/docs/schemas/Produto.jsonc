{"name":"Produto","type":"object","description":"Entidade central de produtos — compartilhada entre Comercial e Logística","properties":{"codigo":{"type":"string","description":"Código interno do produto"},"codigo_omie":{"type":"string","description":"Código de integração no Omie"},"codigo_integracao":{"type":"string","description":"Código em outros sistemas externos"},"cod_barras":{"type":"string","description":"Código de Barras (EAN/GTIN)"},"nome":{"type":"string"},"descricao":{"type":"string","description":"Descrição detalhada do produto"},"tipo":{"type":"string","enum":["produto","servico","equipamento_comodato","embalagem","bonificacao"],"default":"produto","description":"Classificação geral do produto"},"categoria_id":{"type":"string"},"sub_categoria_id":{"type":"string"},"unidade_medida_id":{"type":"string","description":"Unidade de medida principal (UN, CX, KG, L...)"},"unidade_produto_id":{"type":"string","description":"Tipo de produto (linha, família)"},"ncm":{"type":"string","description":"NCM (8 dígitos)"},"cest":{"type":"string","description":"CEST (7 dígitos)"},"imagem_url":{"type":"string"},"status":{"type":"string","enum":["ativo","inativo"],"default":"ativo"},"peso":{"type":"number","default":0,"description":"Peso unitário em kg"},"volume_m3":{"type":"number","default":0,"description":"Volume unitário em m³ — usado no cálculo de capacidade da carga"},"fator_caixa":{"type":"number","default":1,"description":"Quantidade de unidades por caixa fechada (ex: 12 UN por CX)"},"permite_fracionado":{"type":"boolean","default":true,"description":"Permite venda/entrega fracionada (abaixo de 1 caixa)"},"unidade_fracionada":{"type":"string","description":"Unidade usada para venda fracionada (ex: UN quando o padrão é CX)"},"multiplo_carga":{"type":"number","default":1,"description":"Múltiplo mínimo para montagem de carga (ex: apenas em múltiplos de 6)"},"tipo_embalagem":{"type":"string","enum":["caixa","galeia","fardo","saco","lata","pet","vidro","bag","outro"],"description":"Tipo de embalagem — vincula com galeia/caixa quando aplicável"},"galeia_id":{"type":"string","description":"ID do produto de embalagem/galeia associada a este produto (quando tipo_embalagem = galeia)"},"retornavel":{"type":"boolean","default":false,"description":"Indica se a embalagem é retornável (galeia, vasilhame)"},"controla_estoque":{"type":"boolean","default":true,"description":"Define se o produto entra no controle de estoque"},"estoque_atual":{"type":"number","default":0},"estoque_minimo":{"type":"number","default":0,"description":"Ponto de reposição"}},"required":["nome","codigo"]}