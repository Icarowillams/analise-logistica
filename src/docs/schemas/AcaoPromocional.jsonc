{"name":"AcaoPromocional","type":"object","properties":{"tabela_id":{"type":"string","description":"ID da tabela de preço vinculada (opcional)"},"tabela_nome":{"type":"string","description":"Nome da tabela de preço (opcional)"},"produto_id":{"type":"string","description":"ID do produto"},"produto_nome":{"type":"string","description":"Nome do produto"},"produto_codigo":{"type":"string","description":"Código do produto"},"valor_acao":{"type":"number","description":"Preço promocional da ação"},"data_inicio":{"type":"string","format":"date","description":"Data de início da ação"},"data_fim":{"type":"string","format":"date","description":"Data de término da ação"},"clientes_ids":{"type":"array","items":{"type":"string"},"default":[],"description":"IDs dos clientes vinculados à ação"},"clientes_detalhes":{"type":"array","items":{"type":"object","properties":{"cliente_id":{"type":"string"},"cliente_nome":{"type":"string"},"cliente_codigo":{"type":"string"}}},"default":[],"description":"Detalhes dos clientes vinculados"},"status":{"type":"string","enum":["ativa","encerrada","cancelada"],"default":"ativa","description":"Status da ação"},"observacoes":{"type":"string","description":"Observações sobre a ação"}},"required":["produto_id","valor_acao","data_inicio","data_fim"]}