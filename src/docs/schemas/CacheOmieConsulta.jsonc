{"name":"CacheOmieConsulta","type":"object","description":"Cache persistente de respostas de consultas Omie para reduzir chamadas repetidas à API","properties":{"chave":{"type":"string","description":"Chave única gerada por URL + call + parâmetros"},"valor":{"type":"object","description":"Resposta armazenada da API Omie"},"tipo":{"type":"string","description":"Tipo da chamada Omie, ex: ListarClientes, ConsultarPedido, ListarNF"},"expira_em":{"type":"string","format":"date-time","description":"Data/hora de expiração do cache"},"criado_em":{"type":"string","format":"date-time","description":"Data/hora em que o cache foi criado"}},"required":["chave","tipo","expira_em"]}