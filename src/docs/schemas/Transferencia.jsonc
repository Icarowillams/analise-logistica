{"name":"Transferencia","type":"object","description":"Transferência de NF/pedido entre cargas — para reenvio em outra rota/dia","properties":{"pedido_codigo_omie":{"type":"string"},"numero_pedido":{"type":"string"},"numero_nf":{"type":"string"},"cliente_id":{"type":"string"},"cliente_codigo":{"type":"string","description":"Código interno do cliente"},"cliente_nome":{"type":"string"},"carga_origem_id":{"type":"string"},"carga_origem_numero":{"type":"string"},"carga_destino_id":{"type":"string"},"carga_destino_numero":{"type":"string"},"motivo":{"type":"string"},"valor_nf":{"type":"number"},"quantidade_itens":{"type":"number","description":"Quantidade total de unidades transferidas (soma das quantidades dos produtos do pedido)"},"funcionario_id":{"type":"string"},"funcionario_nome":{"type":"string"},"status":{"type":"string","enum":["pendente","concluida","cancelada"],"default":"pendente"}},"required":["pedido_codigo_omie"]}