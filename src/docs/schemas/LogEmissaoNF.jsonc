{"name":"LogEmissaoNF","type":"object","description":"Histórico persistente de cada tentativa de emissão de NF-e via Omie — uma linha por pedido emitido, com status real retornado pela SEFAZ.","properties":{"codigo_pedido":{"type":"string","description":"nCodPed do Omie"},"numero_pedido":{"type":"string"},"numero_nf":{"type":"string","description":"Número da NF autorizada (preenchido apenas se emitida)"},"cliente_id":{"type":"string"},"cliente_nome":{"type":"string"},"carga_id":{"type":"string"},"numero_carga":{"type":"string"},"lote_id":{"type":"string","description":"ID que agrupa os pedidos emitidos no mesmo lote/clique"},"status":{"type":"string","enum":["autorizada","rejeitada","pendente","erro"],"description":"Resultado final da emissão"},"codigo_sefaz":{"type":"string","description":"cStat retornado pela SEFAZ (100=autorizada, 200+=rejeitada)"},"mensagem":{"type":"string","description":"Mensagem completa retornada pelo Omie/SEFAZ"},"boleto_gerado":{"type":"boolean","default":false},"usuario_email":{"type":"string"},"usuario_nome":{"type":"string"}},"required":["codigo_pedido","status"]}