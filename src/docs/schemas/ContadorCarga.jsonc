{"name":"ContadorCarga","type":"object","description":"Sequência persistente de numeração de cargas. Nunca decrementa — independe de cancelamento/exclusão de cargas.","properties":{"chave":{"type":"string","default":"global","description":"Identificador da sequência (sempre 'global' nesta app)"},"ultimo_numero":{"type":"number","default":0,"description":"Último número de carga emitido"}},"required":["chave"]}