{"name":"Perfil","type":"object","description":"Perfis/cargos do sistema — define menus, telas e permissões por papel","properties":{"nome":{"type":"string","description":"Ex: Administrador, Auxiliar de Expedição, Motorista"},"codigo":{"type":"string","enum":["administrador","auxiliar_expedicao","motorista","supervisor","vendedor","gerente"],"description":"Código padronizado do perfil"},"descricao":{"type":"string"},"blocos_acesso":{"type":"array","items":{"type":"string","enum":["cadastros","pedidos","montagem_carga","faturamento","entrega_roteiro","ocorrencias_pos_entrega","relatorios","configuracoes"]},"default":[],"description":"Blocos funcionais visíveis para este perfil"},"permissoes":{"type":"array","items":{"type":"string","enum":["criar_pedido","editar_pedido","cancelar_pedido","montar_carga","fechar_carga","faturar_carga","registrar_entrega","registrar_troca","registrar_retorno","aprovar_cancelamento","aprovar_troca","ver_relatorios","exportar_dados","gerenciar_usuarios","configurar_sistema"]},"default":[],"description":"Permissões granulares do perfil"},"menus_visiveis":{"type":"array","items":{"type":"string"},"default":[],"description":"Lista de paths/páginas visíveis para este perfil"},"status":{"type":"string","enum":["ativo","inativo"],"default":"ativo"}},"required":["nome","codigo"]}