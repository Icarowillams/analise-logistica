{"name":"PrecoProduto","type":"object","properties":{"produto_id":{"type":"string","description":"ID do produto"},"tabela_id":{"type":"string","description":"ID da tabela de preços"},"valor_unitario":{"type":"number","description":"Preço base na tabela"},"valor_acao":{"type":"number","description":"Preço promocional (ação)"},"periodo_acao_fim":{"type":"string","format":"date","description":"Data de término da ação"},"ativacao_acao":{"type":"boolean","default":false,"description":"Se a ação está ativa"},"omie_sincronizado":{"type":"boolean","default":false,"description":"Se o preço foi sincronizado com o Omie"}},"required":["produto_id","tabela_id"]}