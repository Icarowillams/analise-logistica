{"name":"ConfiguracaoImportacao","type":"object","properties":{"app_origem_id":{"type":"string","description":"ID do app de origem"},"app_origem_nome":{"type":"string","description":"Nome do app de origem"},"ultima_importacao":{"type":"string","format":"date-time","description":"Data da última importação"},"total_visitas_importadas":{"type":"number","default":0,"description":"Total de visitas importadas"},"total_estoques_importados":{"type":"number","default":0,"description":"Total de estoques importados"},"total_trocas_importadas":{"type":"number","default":0,"description":"Total de trocas importadas"},"status":{"type":"string","enum":["ativo","pausado"],"default":"ativo","description":"Status da configuração"},"chave":{"type":"string","description":"Chave de configuração interna"},"valor":{"type":"string","description":"Valor da configuração interna"},"descricao":{"type":"string","description":"Descrição da configuração interna"}},"required":[]}