{"name":"LogGerencial","type":"object","description":"Log gerencial de TODAS as ações relevantes feitas no sistema — quem, quando, o que mudou, valor antigo e novo. Auditoria completa.","properties":{"tipo_acao":{"type":"string","enum":["envio","exclusao","edicao","criacao","permissao","faturamento","transferencia","corte","cancelamento","liberacao","LIBERACAO_FORCADA","login","outro"],"description":"Tipo da ação registrada"},"entidade_tipo":{"type":"string","description":"Nome da entidade afetada (Pedido, Cliente, Carga, Permissao...)"},"entidade_id":{"type":"string","description":"ID do registro afetado"},"pedido_id":{"type":"string","description":"ID do pedido relacionado, quando aplicável"},"carga_id":{"type":"string","description":"ID da carga relacionada, quando aplicável"},"cliente_id":{"type":"string","description":"ID do cliente relacionado, quando aplicável"},"entidade_descricao":{"type":"string","description":"Descrição legível do registro (ex: 'Pedido 00005D', 'Cliente João Silva')"},"usuario_email":{"type":"string","description":"Email do usuário que executou a ação"},"usuario_nome":{"type":"string","description":"Nome do usuário que executou a ação"},"descricao":{"type":"string","description":"Descrição completa e legível da ação"},"alteracoes":{"type":"array","default":[],"description":"Lista de campos alterados (apenas em edições)","items":{"type":"object","properties":{"campo":{"type":"string"},"valor_anterior":{"type":"string"},"valor_novo":{"type":"string"}}}},"dados_json":{"type":"string","description":"Dados adicionais em JSON para auditoria detalhada"},"origem":{"type":"string","enum":["frontend","backend","automation","webhook"],"default":"frontend"},"observacao":{"type":"string"}},"required":["tipo_acao","entidade_tipo","usuario_email"]}