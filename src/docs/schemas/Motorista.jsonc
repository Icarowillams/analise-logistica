{"name":"Motorista","type":"object","description":"Motorista operacional — base para carga, roteiro, entrega e custo operacional","properties":{"nome":{"type":"string"},"email":{"type":"string","format":"email"},"cpf":{"type":"string"},"telefone":{"type":"string"},"telefone_2":{"type":"string"},"cnh_numero":{"type":"string"},"cnh_categoria":{"type":"string","enum":["A","B","C","D","E","AB","AC","AD","AE"],"description":"Categoria da CNH"},"cnh_validade":{"type":"string","format":"date"},"veiculo_padrao_id":{"type":"string","description":"Veículo padrão vinculado a este motorista"},"veiculo_padrao_placa":{"type":"string"},"vendedor_id":{"type":"string","description":"ID do registro Vendedor correspondente, se o motorista também for vendedor/funcionário no sistema"},"status":{"type":"string","enum":["ativo","inativo","afastado"],"default":"ativo"},"foto_url":{"type":"string"},"observacoes":{"type":"string"}},"required":["nome"]}